{
  "manifest_version": 3,
  "name": "SNS Emoticon Maker Helper",
  "version": "0.1.0",
  "description": "웹 이미지에서 바로 SNS 이모티콘 메이커를 여는 확장프로그램 초안",
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "background": { "service_worker": "background.js" },
  "host_permissions": ["<all_urls>"]
}
